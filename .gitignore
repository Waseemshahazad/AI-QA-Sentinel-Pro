# Environment Variables (Contains sensitive API keys or local paths)
.env

# App Local Cache / Configuration
config.txt

# Python Runtime / Compiled Bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# PyInstaller & Build Outputs (Prevents staging huge executable directories)
build/
dist/
*.exe
*.spec

# Inno Setup Outputs & Temporary Files
Output/
_IS_*.tmp

# Operating System Specific Files
Thumbs.db
Desktop.ini
.DS_Store

# IDE and Project Specific Settings (PyCharm / VS Code local configs)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.iss
